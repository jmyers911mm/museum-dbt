create or replace temporary table "MUSEUM_DW_PROD"."SILVER"."SNAP_DIM_CUSTOMER__dbt_tmp"
         as
        (
    
    with snapshot_query as (

        



SELECT
    customer_id,
    crm_contact_id,
    full_name,
    primary_email,
    primary_phone,
    email_count,
    phone_count,
    membership_type,
    membership_status,
    customer_segment
FROM MUSEUM_DW_PROD.GOLD.dim_customer


    ),

    snapshotted_data as (

        select *, 
    
        customer_id as dbt_unique_key
    

        from "MUSEUM_DW_PROD"."SILVER"."SNAP_DIM_CUSTOMER"
        where
            
                dbt_valid_to is null
            

    ),

    insertions_source_data as (

        select *, 
    
        customer_id as dbt_unique_key
    
,
            to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as dbt_updated_at,
            to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as dbt_valid_from,
            
  
  coalesce(nullif(to_timestamp_ntz(convert_timezone('UTC', current_timestamp())), to_timestamp_ntz(convert_timezone('UTC', current_timestamp()))), null)
  as dbt_valid_to
,
            md5(coalesce(cast(customer_id as varchar ), '')
         || '|' || coalesce(cast(to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as varchar ), '')
        ) as dbt_scd_id

        from snapshot_query
