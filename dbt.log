  (
    date_day DATE,
    year_num NUMBER,
    quarter_num NUMBER,
    month_num NUMBER,
    month_name VARCHAR,
    week_of_year NUMBER,
    day_of_week_num NUMBER,
    day_name VARCHAR,
    day_of_month NUMBER,
    day_of_year NUMBER,
